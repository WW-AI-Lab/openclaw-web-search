{
  "name": "@ww-ai-lab/openclaw-web-search",
  "version": "2026.4.29",
  "description": "OpenClaw 的独立外部联网搜索插件，逐步适配国产大模型搜索服务",
  "type": "module",
  "private": false,
  "license": "MIT",
  "files": [
    "index.ts",
    "src/provider.ts",
    "src/providers/metaso/metaso-provider.ts",
    "src/providers/metaso/types.ts",
    "src/providers/qwen/qwen-provider.ts",
    "src/providers/shared/config.ts",
    "src/providers/shared/content.ts",
    "src/providers/shared/errors.ts",
    "src/providers/shared/index.ts",
    "src/providers/shared/schema.ts",
    "src/providers/shared/types.ts",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "exports": {
    ".": "./index.ts"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.10",
      "minGatewayVersion": "2026.4.10"
    },
    "build": {
      "openclawVersion": "2026.4.10",
      "pluginSdkVersion": "2026.4.10"
    },
    "install": {
      "minHostVersion": ">=2026.4.10"
    },
    "release": {
      "publishToNpm": true
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/WW-AI-Lab/openclaw-web-search.git"
  },
  "homepage": "https://github.com/WW-AI-Lab/openclaw-web-search#readme",
  "bugs": {
    "url": "https://github.com/WW-AI-Lab/openclaw-web-search/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "web-search",
    "qwen",
    "metaso",
    "dashscope",
    "国产大模型"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.4.10"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.41",
    "openclaw": "file:..",
    "typescript": "^5.9.2",
    "vitest": "^4.1.1"
  }
}
