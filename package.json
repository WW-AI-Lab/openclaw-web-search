{
  "name": "openclaw-web-search",
  "version": "0.1.0",
  "description": "Independent external web_search plugin for OpenClaw",
  "type": "module",
  "private": false,
  "files": [
    "index.ts",
    "src",
    "docs",
    "openclaw.plugin.json",
    "README.md",
    "tsconfig.json"
  ],
  "exports": {
    ".": "./index.ts"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.41",
    "openclaw": "file:..",
    "typescript": "^5.9.2",
    "vitest": "^4.1.1"
  }
}
